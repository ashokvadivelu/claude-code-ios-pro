{
  "_comment": "Global settings for ~/.claude/settings.json. Hooks are provided by the ios-dev-pro plugin — do not duplicate them here. Personal overrides go in ~/.claude/settings.local.json or per-project .claude/settings.local.json.",

  "model": "claude-sonnet-4-5-20250929",

  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "MultiEdit",
      "Grep",
      "Glob",
      "Task",
      "WebSearch",
      "WebFetch",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git stash *)",
      "Bash(git add *)",
      "Bash(swift *)",
      "Bash(swiftlint *)",
      "Bash(swiftformat *)",
      "Bash(xcrun simctl *)",
      "Bash(xcrun mcpbridge *)",
      "Bash(xcodebuild -version)",
      "Bash(xcodebuild -list*)",
      "Bash(brew list *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(jq *)",
      "Bash(rm -rf ~/Library/Developer/Xcode/DerivedData/*)",
      "mcp__xcodebuildmcp__*",
      "mcp__github__*",
      "mcp__sosumi__*",
      "mcp__filesystem__*"
    ],
    "deny": [
      "Read(.env*)",
      "Read(**/Secrets.*)",
      "Read(**/GoogleService-Info.plist)",
      "Read(**/*.p8)",
      "Read(**/*.p12)",
      "Read(**/*.mobileprovision)",
      "Read(**/*.provisionprofile)",
      "Write(.env*)",
      "Write(**/Secrets.*)",
      "Write(**/*.entitlements)",
      "Write(**/Podfile.lock)",
      "Write(**/Package.resolved)",
      "Write(**/.swiftlint.yml)",
      "Write(**/.swiftformat)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git tag*)",
      "Bash(git merge*)",
      "Bash(git rebase*)",
      "Bash(git cherry-pick*)",
      "Bash(git revert*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(git reset --hard origin/*)",
      "Bash(curl * | * sh*)",
      "Bash(curl * | * bash*)",
      "Bash(wget * | * sh*)",
      "Bash(wget * | * bash*)"
    ]
  },

  "env": {
    "CLAUDE_IOS_LINT_MODE": "balanced",
    "DEFAULT_SIMULATOR": "iPhone 16 Pro"
  }
}
